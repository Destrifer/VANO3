---
import WorkCard from "./WorkCard.astro";
import type { Work } from "../lib/works";

// Статичная галерея (не Vue-остров) для карточки продукта. Сетка карточек
// WorkCard внутри .gallery — PhotoSwipe (scripts/gallery-lightbox.ts, грузится
// в простое из BaseLayout) сам навешивает лайтбокс на .gallery a.gallery__link.
// Превью — оптимизированный <picture>, SEO/LCP/CLS не страдают.
interface Props {
  works: Work[];
  title?: string;
}
const { works, title = "Примеры работ" } = Astro.props;
---

{
  works.length > 0 && (
    <section class="gallery">
      {title && <h2 class="mb-3 text-lg font-bold">{title}</h2>}
      <div class="gallery__grid">
        {works.map((w) => (
          <WorkCard work={w} />
        ))}
      </div>
    </section>
  )
}

<style>
  /* Только раскладка: ширина-ориентир — сама колонка галереи (container query),
     а не экран. Максимум 2 крупные миниатюры в ряд → 1 при сужении. */
  .gallery {
    container-type: inline-size;
  }
  .gallery__grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  @container (min-width: 420px) {
    .gallery__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
