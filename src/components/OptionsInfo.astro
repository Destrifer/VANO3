---
// Блок «Материалы и технологии» — карточки-ячейки (по типу материала + постпечать).
// В каждой ячейке: список слева (daisyUI menu) + превью справа (квадратный тумб +
// описание). Все панели в HTML (краулится, П6); лёгкий прогрессивный JS только
// переключает видимость. Картинка пока единый плейсхолдер; реальные — позже из
// papers.image / finishing_options.image.
import { Picture } from "astro:assets";
import placeholder from "../assets/materials/placeholder.jpg";
import type { ProductPricing } from "../lib/pricing/data";
import { optionInfo } from "../lib/optionInfo";

const { papers = [], finishing = [], foldTypes = [], allowContourCut = false } =
  Astro.props as {
    papers?: ProductPricing["papers"];
    finishing?: ProductPricing["finishing"];
    foldTypes?: ProductPricing["foldTypes"];
    allowContourCut?: boolean;
  };

type Item = { name: string; description: string | null };
const cards: { title: string; items: Item[] }[] = [];

// Материалы по группам (group = тип материала).
const paperGroups = new Map<string, Item[]>();
for (const p of papers) {
  const g = p.group || "Материалы";
  if (!paperGroups.has(g)) paperGroups.set(g, []);
  paperGroups.get(g)!.push({ name: p.name, description: p.description });
}
for (const [title, items] of paperGroups) cards.push({ title, items });

// Постпечать: концепты из групп отделки + признаков продукта (у кого есть текст).
const concepts: string[] = [
  ...new Set(finishing.map((f) => f.group).filter((g): g is string => !!g)),
];
if (foldTypes.length) concepts.push("Фальцовка");
if (allowContourCut) concepts.push("Контурная резка");
const postpress = concepts
  .map((c) => ({ name: c, description: optionInfo(c) }))
  .filter((x) => x.description);
if (postpress.length) cards.push({ title: "Постпечать и отделка", items: postpress });
---

{
  cards.length > 0 && (
    <section class="my-10">
      <h2 class="mb-4 text-xl font-bold">Материалы и технологии</h2>
      <div class="materials-grid">
        {cards.map((card, ci) => (
          <div class="options-cell card border border-base-300 bg-base-100 shadow-sm" data-cell={ci}>
            <div class="card-body gap-3 p-4">
              <h3 class="card-title text-base">{card.title}</h3>
              <div class="cell-layout">
                {/* список слева */}
                <ul class="menu menu-sm w-full gap-0.5 p-0">
                  {card.items.map((it, i) => (
                    <li>
                      <button
                        type="button"
                        class={`opt-tab ${i === 0 ? "menu-active" : ""}`}
                        data-idx={i}
                      >
                        {it.name}
                      </button>
                    </li>
                  ))}
                </ul>
                {/* превью справа (рядом со списком, когда карточка широкая) */}
                <div class="cell-preview">
                  {card.items.map((it, i) => (
                    <div class={`opt-panel flex gap-4 ${i === 0 ? "" : "hidden"}`} data-idx={i}>
                      <Picture
                        src={placeholder}
                        width={320}
                        height={320}
                        fit="cover"
                        position="center"
                        formats={["avif", "webp"]}
                        quality={50}
                        alt={it.name}
                        class="size-32 shrink-0 rounded-box object-cover"
                      />
                      <div>
                        <p class="font-semibold">{it.name}</p>
                        <p class="mt-1 text-sm text-base-content/70">
                          {it.description ?? "Описание появится позже."}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

<script>
  // Прогрессивное переключение: клик по пункту списка показывает его превью.
  // Весь контент уже в HTML — JS лишь меняет видимость.
  document.querySelectorAll<HTMLElement>(".options-cell").forEach((cell) => {
    const tabs = cell.querySelectorAll<HTMLElement>(".opt-tab");
    const panels = cell.querySelectorAll<HTMLElement>(".opt-panel");
    cell.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".opt-tab");
      if (!btn) return;
      const idx = btn.dataset.idx;
      tabs.forEach((b) => b.classList.toggle("menu-active", b === btn));
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.idx !== idx));
    });
  });
</script>

<style>
  /* Умная сетка: браузер сам кладёт столько колонок, сколько влезает при
     ширине ≥24rem (на широких — 3, на узких — 1-2). min(100%) — без переполнения. */
  .materials-grid {
    display: grid;
    gap: 1rem;
    align-items: start;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 24rem), 1fr));
  }
  /* Каждая карточка — container: внутренняя раскладка реагирует на ЕЁ ширину. */
  .options-cell {
    container-type: inline-size;
  }
  /* По умолчанию (узкая карточка): список над превью. */
  .cell-layout {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  /* Широкая карточка — список слева, превью справа. */
  @container (min-width: 26rem) {
    .cell-layout {
      grid-template-columns: 14rem 1fr;
    }
    .cell-preview {
      border-left: 1px solid var(--color-base-200);
      padding-left: 1rem;
    }
  }
</style>
