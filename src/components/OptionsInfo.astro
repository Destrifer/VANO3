---
// Блок «Материалы и технологии» — единый мастер-детейл интерфейс.
// Слева: сгруппированный список всех материалов и технологий (daisyUI menu).
// Справа: превью + описание выбранного пункта. Один активный элемент на весь блок.
// Все панели в HTML (краулится, П6); лёгкий прогрессивный JS переключает видимость.
// Материалы берут реальные картинки из papers.image; постпечать пока падает в общий плейсхолдер.
import { Picture } from "astro:assets";
import placeholder from "../assets/materials/placeholder.jpg";
import type { ProductPricing } from "../lib/pricing/data";
import { optionInfo } from "../lib/optionInfo";

const {
  papers = [],
  finishing = [],
  foldTypes = [],
  allowContourCut = false,
  class: className = "",
} = Astro.props as {
  papers?: ProductPricing["papers"];
  finishing?: ProductPricing["finishing"];
  foldTypes?: ProductPricing["foldTypes"];
  allowContourCut?: boolean;
  class?: string;
};

type Item = { name: string; description: string | null; image: string | null };
const groupsRaw: { title: string; items: Item[] }[] = [];

// Тип материала — из Directus (papers.material_type). Группируем по нему; порядок
// групп = порядок первого появления бумаги (задаётся в админке сортировкой бумаг),
// без хардкода. Map сохраняет порядок вставки.
const paperGroups = new Map<string, Item[]>();
for (const p of papers) {
  const g = p.materialType || "Прочее";
  if (!paperGroups.has(g)) paperGroups.set(g, []);
  paperGroups.get(g)!.push({ name: p.name, description: p.description, image: p.image });
}
for (const [title, items] of paperGroups) groupsRaw.push({ title, items });

// Постпечать: концепты из групп отделки + признаков продукта (у кого есть текст).
// Фото берём из finishing_options своей группы (первое с картинкой); концепты-флаги
// (Фальцовка, Контурная резка) своего finishing-ряда не имеют → плейсхолдер.
const groupImage = new Map<string, string>();
for (const f of finishing) {
  if (f.group && f.image && !groupImage.has(f.group)) groupImage.set(f.group, f.image);
}
const concepts: string[] = [
  ...new Set(finishing.map((f) => f.group).filter((g): g is string => !!g)),
];
if (foldTypes.length) concepts.push("Фальцовка");
if (allowContourCut) concepts.push("Контурная резка");
const postpress = concepts
  .map((c) => ({ name: c, description: optionInfo(c), image: groupImage.get(c) ?? null }))
  .filter((x) => x.description);
if (postpress.length) groupsRaw.push({ title: "Постпечать и отделка", items: postpress });

// Глобальная нумерация: единый активный пункт на весь блок (idx 0 — по умолчанию).
let counter = 0;
const groups = groupsRaw.map((g) => ({
  title: g.title,
  items: g.items.map((it) => ({ ...it, idx: counter++ })),
}));
const flat = groups.flatMap((g) => g.items);
---

{
  flat.length > 0 && (
    <section class={className}>
      <h2 class="mb-4 text-xl font-bold">Материалы и технологии</h2>

      <div class="options-panel card overflow-hidden border border-base-300 bg-base-100 shadow-sm">
        <div class="panel-layout">
          {/* Слева: выбор материала/технологии */}
          <ul class="menu menu-sm panel-nav flex-nowrap gap-0.5 p-2">
            {groups.map((g) => (
              <>
                <li class="menu-title px-2 pt-2 pb-1 text-xs uppercase tracking-wide">
                  {g.title}
                </li>
                {g.items.map((it) => (
                  <li>
                    <button
                      type="button"
                      class={`opt-tab whitespace-normal text-left ${it.idx === 0 ? "menu-active" : ""}`}
                      data-idx={it.idx}
                    >
                      {it.name}
                    </button>
                  </li>
                ))}
              </>
            ))}
          </ul>

          {/* Справа: превью + описание выбранного */}
          <div class="panel-preview p-5">
            {flat.map((it) => (
              <div class={`opt-panel ${it.idx === 0 ? "" : "hidden"}`} data-idx={it.idx}>
                <div class="overflow-hidden rounded-box">
                  {it.image ? (
                    <Picture
                      src={it.image}
                      width={480}
                      height={270}
                      fit="cover"
                      position="center"
                      densities={[1, 2]}
                      formats={["avif", "webp"]}
                      quality={60}
                      alt={it.name}
                      loading={it.idx === 0 ? "eager" : "lazy"}
                      class="aspect-video w-full object-cover"
                    />
                  ) : (
                    <Picture
                      src={placeholder}
                      width={640}
                      height={360}
                      fit="cover"
                      position="center"
                      formats={["avif", "webp"]}
                      quality={50}
                      alt={it.name}
                      class="aspect-video w-full object-cover"
                    />
                  )}
                </div>
                <p class="mt-4 text-lg font-semibold">{it.name}</p>
                <p class="mt-1 leading-relaxed text-base-content/70">
                  {it.description ?? "Описание появится позже."}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  // Прогрессивное переключение: клик по пункту слева показывает его превью справа.
  // Весь контент уже в HTML — JS лишь меняет видимость (один активный на блок).
  document.querySelectorAll<HTMLElement>(".options-panel").forEach((panel) => {
    const tabs = panel.querySelectorAll<HTMLElement>(".opt-tab");
    const panels = panel.querySelectorAll<HTMLElement>(".opt-panel");
    panel.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".opt-tab");
      if (!btn) return;
      const idx = btn.dataset.idx;
      tabs.forEach((b) => b.classList.toggle("menu-active", b === btn));
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.idx !== idx));
    });
  });
</script>

<style>
  /* Карточка реагирует на собственную ширину (container query). */
  .options-panel {
    container-type: inline-size;
  }
  /* По умолчанию (узко): список сверху, превью снизу. */
  .panel-layout {
    display: grid;
    grid-template-columns: 1fr;
  }
  .panel-nav {
    max-height: 16rem;
    overflow-y: auto;
    overflow-x: hidden;
    border-bottom: 1px solid var(--color-base-200);
  }
  /* Шире 26rem: список слева, превью справа. */
  @container (min-width: 26rem) {
    .panel-layout {
      grid-template-columns: 15rem 1fr;
    }
    .panel-nav {
      max-height: 26rem;
      border-bottom: none;
      border-right: 1px solid var(--color-base-200);
    }
  }
</style>
