---
// Авто-блок «Материалы и технологии». Product-agnostic: из опций продукта.
// Группы по papers.group (тип материала) и по finishing.group (постпечать).
// Внутри группы — выбор варианта (daisyUI tabs на радио = чистый CSS, без JS,
// без попапа; все панели в HTML → краулится, П6). В панели — квадратный тумб
// (astro:assets: cover-кроп + avif/webp) + описание.
// Картинка пока единый плейсхолдер; реальные — в papers.image/finishing_options.image.
import { Picture } from "astro:assets";
import placeholder from "../assets/materials/placeholder.jpg";
import type { ProductPricing } from "../lib/pricing/data";
import { optionInfo } from "../lib/optionInfo";

const { papers = [], finishing = [], foldTypes = [], allowContourCut = false } =
  Astro.props as {
    papers?: ProductPricing["papers"];
    finishing?: ProductPricing["finishing"];
    foldTypes?: ProductPricing["foldTypes"];
    allowContourCut?: boolean;
  };

// Материалы по группам (group = тип материала).
const paperGroups = new Map<string, typeof papers>();
for (const p of papers) {
  const g = p.group || "Материалы";
  if (!paperGroups.has(g)) paperGroups.set(g, []);
  paperGroups.get(g)!.push(p);
}

// Постпечать: концепты из групп отделки + признаков продукта (у кого есть текст).
const concepts: string[] = [
  ...new Set(finishing.map((f) => f.group).filter((g): g is string => !!g)),
];
if (foldTypes.length) concepts.push("Фальцовка");
if (allowContourCut) concepts.push("Контурная резка");
const conceptItems = concepts
  .map((c) => ({ title: c, text: optionInfo(c) }))
  .filter((x): x is { title: string; text: string } => !!x.text);

const hasContent = paperGroups.size > 0 || conceptItems.length > 0;
---

{
  hasContent && (
    <section class="my-10">
      <h2 class="mb-4 text-xl font-bold">Материалы и технологии</h2>

      {paperGroups.size > 0 && (
        <div class="mb-8 space-y-5">
          {[...paperGroups.entries()].map(([group, items], gi) => (
            <div>
              <p class="mb-2 text-sm font-medium text-base-content/70">{group}</p>
              <div role="tablist" class="tabs tabs-box">
                {items.map((p, i) => (
                  <>
                    <input
                      type="radio"
                      name={`mat-${gi}`}
                      role="tab"
                      class="tab"
                      aria-label={p.name}
                      checked={i === 0}
                    />
                    <div role="tabpanel" class="tab-content p-3">
                      <div class="flex gap-4">
                        <Picture
                          src={placeholder}
                          width={300}
                          height={300}
                          fit="cover"
                          position="center"
                          formats={["avif", "webp"]}
                          quality={50}
                          alt={p.name}
                          class="size-28 shrink-0 rounded-box object-cover"
                        />
                        <div>
                          <p class="font-semibold">{p.name}</p>
                          <p class="mt-1 text-sm text-base-content/70">
                            {p.description ?? "Описание появится позже."}
                          </p>
                        </div>
                      </div>
                    </div>
                  </>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

      {conceptItems.length > 0 && (
        <div>
          <p class="mb-2 text-sm font-medium text-base-content/70">Постпечать и отделка</p>
          <div role="tablist" class="tabs tabs-box">
            {conceptItems.map((c, i) => (
              <>
                <input
                  type="radio"
                  name="postpress"
                  role="tab"
                  class="tab"
                  aria-label={c.title}
                  checked={i === 0}
                />
                <div role="tabpanel" class="tab-content p-3">
                  <div class="flex gap-4">
                    <Picture
                      src={placeholder}
                      width={300}
                      height={300}
                      fit="cover"
                      position="center"
                      formats={["avif", "webp"]}
                      quality={50}
                      alt={c.title}
                      class="size-28 shrink-0 rounded-box object-cover"
                    />
                    <div>
                      <p class="font-semibold">{c.title}</p>
                      <p class="mt-1 text-sm text-base-content/70">{c.text}</p>
                    </div>
                  </div>
                </div>
              </>
            ))}
          </div>
        </div>
      )}
    </section>
  )
}
