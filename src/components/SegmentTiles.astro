---
// Плитки «виды/опции» на хабе — ссылки-карточки на кластерные страницы (Tier-1).
// Тот же вид, что у карточек на главной (ProductTile), но с ценой по пресету и
// БЕЗ срока (чтобы не раздувать). Пусто → ничего не рендерит.
import ProductTile from "./ProductTile.astro";

interface Tile {
  name: string;
  href: string;
  priceFrom?: number | null;
}
const { items = [], heading = "Виды и опции" } = Astro.props as {
  items?: Tile[];
  heading?: string;
};
---

{
  items.length > 0 && (
    <section class="my-10">
      <h2 class="mb-4 text-xl font-bold">{heading}</h2>
      <ul class="product-grid">
        {items.map((t) => (
          <ProductTile href={t.href} name={t.name} priceFrom={t.priceFrom ?? null} />
        ))}
      </ul>
    </section>
  )
}
