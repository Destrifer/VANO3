---
// Плитки-альтернативы (кластеры Tier-1) — компактные квадратные карточки с
// иконкой и ценой по пресету, БЕЗ заголовка. Размещаются в правом верхнем углу
// хаба/кластера (первый экран, не съедают калькулятор). Пусто → ничего.
import ProductTile from "./ProductTile.astro";

interface Tile {
  name: string;
  href: string;
  icon?: string | null;
  priceFrom?: number | null;
}
const { items = [], label = "Похожие виды" } = Astro.props as {
  items?: Tile[];
  label?: string;
};
---

{
  items.length > 0 && (
    <nav class="segment-nav" aria-label={label}>
      <ul class="segment-nav__grid">
        {items.map((t) => (
          <ProductTile
            href={t.href}
            name={t.name}
            icon={t.icon ?? null}
            priceFrom={t.priceFrom ?? null}
            compact
          />
        ))}
      </ul>
    </nav>
  )
}
