---
// Ряд сегментов-кластеров (Tier-1) — компактные плитки «иконка + название + цена
// по пресету», БЕЗ заголовка. Горизонтальный ряд под H1 хаба/кластера. На
// кластере текущий сегмент подсвечен (activeHref). Пусто → ничего.
import ProductTile from "./ProductTile.astro";

interface Tile {
  name: string;
  href: string;
  icon?: string | null;
  priceFrom?: number | null;
}
const { items = [], label = "Похожие виды", activeHref = null } = Astro.props as {
  items?: Tile[];
  label?: string;
  activeHref?: string | null;
};
---

{
  items.length > 0 && (
    <nav class="segment-nav" aria-label={label}>
      <ul class="segment-nav__grid">
        {items.map((t) => (
          <ProductTile
            href={t.href}
            name={t.name}
            icon={t.icon ?? null}
            priceFrom={t.priceFrom ?? null}
            active={activeHref != null && t.href === activeHref}
            compact
          />
        ))}
      </ul>
    </nav>
  )
}
