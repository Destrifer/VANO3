---
// Карточка-плитка: иконка + название + цена «от» + (опц.) срок готовности.
// Общая для сетки на главной и для плиток кластеров на хабе (единый вид).
import { Icon } from "astro-icon/components";
import ReadyBadge from "./ReadyBadge.astro";

interface Props {
  href: string;
  name: string;
  icon?: string | null;
  priceFrom?: number | null;
  leadDays?: number | null; // если задан — показываем бейдж срока готовности
  compact?: boolean; // компактная плитка (правый верхний блок альтернатив)
}
const {
  href,
  name,
  icon = null,
  priceFrom = null,
  leadDays = null,
  compact = false,
} = Astro.props;
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });
const priceLabel = priceFrom != null ? `от ${money(priceFrom)} ₽` : "Рассчитать";
---

<li>
  <a class={`product-tile${compact ? " product-tile--compact" : ""}`} href={href}>
    {icon && <Icon name={icon} class="product-tile__icon" />}
    <span class="product-tile__name">{name}</span>
    <span class="product-tile__meta">{priceLabel}</span>
    {leadDays != null && <ReadyBadge leadDays={leadDays} />}
  </a>
</li>
