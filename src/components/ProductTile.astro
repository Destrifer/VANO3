---
// Карточка-плитка: иконка + название + мета («от X ₽», опционально срок).
// Общая для сетки на главной и для плиток кластеров на хабе (единый вид, без дублей).
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  name: string;
  icon?: string | null;
  priceFrom?: number | null;
  lead?: string | null; // срок («1–3 дня»); если null — не показываем (кластеры)
}
const { href, name, icon = null, priceFrom = null, lead = null } = Astro.props;
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });
const priceLabel = priceFrom != null ? `от ${money(priceFrom)} ₽` : "Рассчитать";
const meta = lead ? `${priceLabel} · ${lead}` : priceLabel;
---

<li>
  <a class="product-tile" href={href}>
    {icon && <Icon name={icon} class="product-tile__icon" />}
    <span class="product-tile__name">{name}</span>
    <span class="product-tile__meta">{meta}</span>
  </a>
</li>
