---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getHomeProducts } from "../lib/products";
import { getPricingData, getProductPricing, defaultPrice, HOME_BASE_QTY } from "../lib/pricing/data";

const [homeProducts, pricing] = await Promise.all([
  getHomeProducts(),
  getPricingData(),
]);

// Цена «от» считается на сборке тем же движком (дефолт. конфиг калькулятора).
// Подорожает бумага/печать в Directus → пересборка пересчитает все плитки.
const products = await Promise.all(
  homeProducts.map(async (p) => {
    const pricingConfig = await getProductPricing(p.slug);
    const price = pricingConfig ? defaultPrice(pricingConfig, pricing) : null;
    return { ...p, price };
  }),
);

const pageTitle = "Printmos — цифровая типография в Москве";
const pageDescription =
  "Printmos — цифровая типография в Москве: визитки, листовки, буклеты, каталоги, наклейки, баннеры и срочная печать для бизнеса.";

const lead = "1–3 дня";
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <h1 class="home-title">Что нужно напечатать?</h1>

  <ul class="product-grid">
    {
      products.map((product) => (
        <li>
          <a class="product-tile" href={`/${product.slug}`}>
            {product.icon && (
              <Icon name={product.icon} class="product-tile__icon" />
            )}
            <span class="product-tile__name">{product.name}</span>
            <span class="product-tile__meta">
              {product.price != null ? `от ${money(product.price)} ₽` : "Рассчитать"} · {lead}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
