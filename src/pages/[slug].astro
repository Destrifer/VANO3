---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getCategories } from "../lib/categories";
import { getProducts } from "../lib/products";
import { getProductPricing, getPricingData, minPrice } from "../lib/pricing/data";
import { getWorks, type Work } from "../lib/works";
import { getServiceContent, type ServiceContent } from "../lib/services";
import { productOffer, faqPage } from "../lib/seo/jsonld";
import ProductConfigurator from "../components/ProductConfigurator.vue";
import Gallery from "../components/Gallery.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SegmentTiles from "../components/SegmentTiles.astro";

// getStaticPaths сообщает Astro, какие страницы сгенерировать (SSG).
// Возвращаем по записи на каждую категорию и каждый продукт.
export async function getStaticPaths() {
  const [categories, products] = await Promise.all([
    getCategories(),
    getProducts(),
  ]);

  // быстрый доступ «id категории → данные» для карточки продукта
  const categoryById = new Map(categories.map((c) => [c.id, c]));

  const categoryPaths = categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      type: "category" as const,
      name: category.name,
      icon: category.icon,
      // продукты этой категории — для списка на странице группы
      items: products
        .filter((p) => p.category === category.id)
        .map((p) => ({ name: p.name, slug: p.slug, icon: p.icon ?? category.icon })),
    },
  }));

  const productPaths = products.map((product) => {
    const parent = categoryById.get(product.category);
    return {
      params: { slug: product.slug },
      props: {
        type: "product" as const,
        name: product.name,
        icon: product.icon ?? parent?.icon ?? null, // фолбэк на иконку категории
        parentName: parent?.name ?? null,
        parentSlug: parent?.slug ?? null,
      },
    };
  });

  return [...categoryPaths, ...productPaths];
}

const props = Astro.props;
const slug = Astro.params.slug!;
const siteUrl = Astro.site?.toString() ?? "https://printmos.ru";
const pageUrl = new URL(`/${slug}`, siteUrl).toString();
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });

// Хлебные крошки: Главная → (категория) → текущая.
const crumbs =
  props.type === "category"
    ? [
        { name: "Главная", href: "/" },
        { name: props.name, href: `/${slug}` },
      ]
    : [
        { name: "Главная", href: "/" },
        ...(props.parentSlug
          ? [{ name: props.parentName!, href: `/${props.parentSlug}` }]
          : []),
        { name: props.name, href: `/${slug}` },
      ];

// Для продукта: ценовой конфиг, цена «от», примеры работ, SEO-контент.
let productPricing = null;
let pricing = null;
let works: Work[] = [];
let content: ServiceContent | null = null;
let lowPrice: number | null = null;
if (props.type === "product") {
  productPricing = await getProductPricing(slug);
  // Калькулятор показываем, если есть данные под стратегию.
  const hasCalc =
    !!productPricing &&
    (productPricing.papers.length > 0 ||
      (productPricing.strategy === "multipage" && productPricing.bindings.length > 0) ||
      (productPricing.strategy === "fixed" && productPricing.fixedPrice.length > 0));
  if (hasCalc) pricing = await getPricingData();
  works = await getWorks({ product: slug });
  content = await getServiceContent(slug);
  if (productPricing && pricing) lowPrice = minPrice(productPricing, pricing);
}

// H1 / мета / JSON-LD страницы.
const h1 = (props.type === "product" && content?.h1) || props.name;
let pageTitle: string;
let pageDescription: string;
const jsonLd: Record<string, unknown>[] = [];
if (props.type === "product") {
  pageTitle =
    content?.metaTitle ??
    `${props.name} в Москве${lowPrice != null ? ` — от ${money(lowPrice)} ₽` : ""} | Printmos`;
  pageDescription =
    content?.metaDescription ??
    `${props.name} на заказ в Москве. Расчёт цены онлайн в конфигураторе, срок от 1 дня. Доставка по Москве и РФ.`;
  jsonLd.push(
    productOffer({ name: props.name, url: pageUrl, lowPrice, description: pageDescription }),
  );
  if (content && content.faq.length > 0) jsonLd.push(faqPage(content.faq));
} else {
  pageTitle = `${props.name} — Printmos`;
  pageDescription = `${props.name}: услуги печати в Москве.`;
}
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Breadcrumbs items={crumbs} />
  <p class="stub-kicker">
    {props.type === "category" ? "Категория" : "Продукт"}
  </p>
  <h1 class="stub-title">
    {props.icon && <Icon name={props.icon} class="stub-icon" />}
    {h1}
  </h1>

  {
    props.type === "category" && (
      <>
        <p>Страница категории — в разработке. Что входит в категорию:</p>
        <ul class="stub-list">
          {props.items.map((item) => (
            <li>
              <a href={`/${item.slug}`}>
                {item.icon && <Icon name={item.icon} class="menu-icon" />}
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </>
    )
  }

  {
    props.type === "product" && (
      <>
        {/* Первый экран: конфигуратор (мгновенная цена) */}
        {pricing && productPricing ? (
          <ProductConfigurator
            client:load
            product={productPricing}
            pricing={pricing}
            name={props.name}
            slug={slug}
          >
            <Gallery slot="gallery" works={works} />
          </ProductConfigurator>
        ) : (
          <>
            <p>Карточка продукта — калькулятор появится позже.</p>
            <Gallery works={works} />
          </>
        )}

        {/* Плитки видов/опций → кластерные страницы (наполнятся в Фазе 5) */}
        <SegmentTiles items={[]} />

        {/* Характеристики текстом — главный SEO-актив (05 §24), из Directus с фолбэком */}
        <section class="my-10 max-w-prose">
          <h2 class="mb-3 text-xl font-bold">{props.name} в Москве</h2>
          {content?.characteristics ? (
            <div set:html={content.characteristics} />
          ) : content?.introText ? (
            <div set:html={content.introText} />
          ) : (
            <p class="text-base-content/80">
              {props.name} — печать на заказ в Москве. Расчёт стоимости — мгновенно
              в конфигураторе выше. Срок от 1 рабочего дня. Доставка по Москве и РФ.
            </p>
          )}
        </section>

        {/* Требования к макету + скачиваемый шаблон */}
        {content?.templateUrl && (
          <section class="my-8 max-w-prose">
            <h2 class="mb-3 text-xl font-bold">Требования к макету</h2>
            <p>
              <a class="link" href={content.templateUrl} download>
                Скачать шаблон макета
              </a>{" "}
              · <a class="link link-hover" href="/guides">гайд по подготовке файла</a>
            </p>
          </section>
        )}

        {/* FAQ (FAQPage JSON-LD уже в <head>) */}
        {content && content.faq.length > 0 && (
          <section class="my-10 max-w-prose">
            <h2 class="mb-4 text-xl font-bold">Частые вопросы</h2>
            {content.faq.map((f) => (
              <details class="collapse collapse-arrow mb-2 border border-base-content">
                <summary class="collapse-title font-medium">{f.question}</summary>
                <div class="collapse-content">
                  <p>{f.answer}</p>
                </div>
              </details>
            ))}
          </section>
        )}

        {/* Вверх по иерархии */}
        {props.parentSlug && (
          <p class="my-6 text-base-content/60">
            Категория:{" "}
            <a class="link link-hover" href={`/${props.parentSlug}`}>
              {props.parentName}
            </a>
          </p>
        )}
      </>
    )
  }
</BaseLayout>
