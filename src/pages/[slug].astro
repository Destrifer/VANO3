---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getCategories } from "../lib/categories";
import { getProducts } from "../lib/products";
import { getProductPricing, getPricingData, minPrice } from "../lib/pricing/data";
import { getWorks, type Work } from "../lib/works";
import { getServiceContent, type ServiceContent } from "../lib/services";
import { productOffer, faqPage } from "../lib/seo/jsonld";
import ProductConfigurator from "../components/ProductConfigurator.vue";
import Gallery from "../components/Gallery.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SegmentTiles from "../components/SegmentTiles.astro";
import OptionsInfo from "../components/OptionsInfo.astro";
import Faq from "../components/Faq.astro";
import type { ServiceFaq } from "../lib/services";

// TODO(temp): рыба для тест-верстки FAQ, пока поле `faq` не наполнено в Directus
// (Этап 2). Показываем только на странице визиток. Убрать после наполнения.
const FISH_FAQ: ServiceFaq[] = [
  {
    question: "Сколько стоит напечатать визитки?",
    answer:
      "Цена зависит от тиража и бумаги: чем больше тираж, тем ниже цена за штуку. Стандартные визитки 90×50 мм — от 1,5 ₽/шт при тираже 1000. Точную стоимость под вашу бумагу, ламинацию и тираж считает конфигуратор выше — мгновенно, без заявки.",
  },
  {
    question: "Какие сроки изготовления визиток?",
    answer:
      "Стандартный срок — от 1 рабочего дня. Есть срочная печать: при заказе до 12:00 простые визитки успеваем сделать в день обращения. Сроки с ламинацией, фольгой или вырубкой — на 1–2 дня дольше, точную дату готовности конфигуратор показывает при расчёте.",
  },
  {
    question: "Нужен ли готовый макет или вы поможете?",
    answer:
      "Можно прислать готовый макет (PDF/TIFF в CMYK, 300 dpi, с вылетами 2 мм) — скачайте наш шаблон, чтобы ничего не обрезалось. Если макета нет, поможем подготовить: правки текста и базовую вёрстку делаем, сложный дизайн с нуля — по согласованию.",
  },
  {
    question: "Какая плотность бумаги используется для визиток?",
    answer:
      "Базовая плотность — 300–350 г/м². Это плотный картон, который не гнётся в руках и не выглядит дёшево. Для дизайнерских визиток доступны бумаги до 640 г/м², а также фактурные, хлопковые и софт-тач варианты — все доступные опции есть в конфигураторе.",
  },
  {
    question: "Какой минимальный тираж?",
    answer:
      "Минимальный тираж — от 100 штук. Меньше печатать невыгодно: цена за штуку будет почти как за 100. Оптимально по соотношению цена/качество — тиражи от 500 шт, на них уже работает скидка за объём.",
  },
  {
    question: "Делаете двусторонние визитки?",
    answer:
      "Да, печатаем и односторонние, и двусторонние. Двусторонние удобны, когда нужно разместить больше информации: контакты с одной стороны, услуги или QR-код — с другой. Сторона печати выбирается в конфигураторе, на цену влияет незначительно.",
  },
];

// TODO(temp): рыба intro_text для визиток (поле пока пусто в Directus). Вхождения
// головы + ключевые числа (форматы/тираж/плотность/срок) + контекстные ссылки
// (часть на плитки Tier-1 ведёт в никуда до Фазы 5).
const FISH_INTRO = `
<p>Печатаем <strong>визитки в Москве</strong> на собственном цифровом оборудовании — от стандартных до премиальных, без посредников и типографий-перекупщиков. Рассчитать стоимость и заказать визитки можно прямо в конфигураторе выше: цена обновляется мгновенно, без заявки и ожидания менеджера. Стандартный размер — 90×50 мм, делаем и евро-формат 85×55 мм, и нестандартные форматы с вырубкой. Минимальный тираж — от 100 штук, печать односторонняя и двусторонняя, с доставкой по Москве и России.</p>
<p>Под задачу подберём материал и отделку. Нужно срочно — сделаем <a href="/business-cards/srochnye">срочную печать визиток за 1 день</a>, успеваем в день обращения при заказе до 12:00. Хотите, чтобы визитка выделялась и запоминалась, — посмотрите <a href="/business-cards/foilirovanie">визитки с фольгированием</a> золотом или серебром, либо варианты <a href="/business-cards/dizajnerskie">на дизайнерской бумаге</a> плотностью до 640 г/м² с фактурой льна и софт-тач. Стандартные тиражи печатаем на плотном картоне 300–350 г/м² с ламинацией на выбор.</p>
<p>Перед заказом советуем заглянуть в <a href="/guides">гайд по подготовке макета</a> — это помогает отправить файл в печать с первого раза, без правок и задержек. Принимаем макеты в PDF и TIFF (CMYK, 300 dpi); если готового дизайна нет — подскажем по требованиям. Работаем с физлицами и по счёту для юрлиц, оплата картой, СБП или наличными. А если кроме визиток нужны <a href="/leaflets">листовки</a> или другая полиграфия — напечатаем в едином стиле одним заказом и одной доставкой.</p>
`;

// getStaticPaths сообщает Astro, какие страницы сгенерировать (SSG).
// Возвращаем по записи на каждую категорию и каждый продукт.
export async function getStaticPaths() {
  const [categories, products] = await Promise.all([
    getCategories(),
    getProducts(),
  ]);

  // быстрый доступ «id категории → данные» для карточки продукта
  const categoryById = new Map(categories.map((c) => [c.id, c]));

  const categoryPaths = categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      type: "category" as const,
      name: category.name,
      icon: category.icon,
      // продукты этой категории — для списка на странице группы
      items: products
        .filter((p) => p.category === category.id)
        .map((p) => ({ name: p.name, slug: p.slug, icon: p.icon ?? category.icon })),
    },
  }));

  const productPaths = products.map((product) => {
    const parent = categoryById.get(product.category);
    return {
      params: { slug: product.slug },
      props: {
        type: "product" as const,
        name: product.name,
        icon: product.icon ?? parent?.icon ?? null, // фолбэк на иконку категории
        parentName: parent?.name ?? null,
        parentSlug: parent?.slug ?? null,
      },
    };
  });

  return [...categoryPaths, ...productPaths];
}

const props = Astro.props;
const slug = Astro.params.slug!;
const siteUrl = Astro.site?.toString() ?? "https://printmos.ru";
const pageUrl = new URL(`/${slug}`, siteUrl).toString();
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });

// Хлебные крошки: Главная → (категория) → текущая.
const crumbs =
  props.type === "category"
    ? [
        { name: "Главная", href: "/" },
        { name: props.name, href: `/${slug}` },
      ]
    : [
        { name: "Главная", href: "/" },
        ...(props.parentSlug
          ? [{ name: props.parentName!, href: `/${props.parentSlug}` }]
          : []),
        { name: props.name, href: `/${slug}` },
      ];

// Для продукта: ценовой конфиг, цена «от», примеры работ, SEO-контент.
let productPricing = null;
let pricing = null;
let works: Work[] = [];
let content: ServiceContent | null = null;
let lowPrice: number | null = null;
if (props.type === "product") {
  productPricing = await getProductPricing(slug);
  // Калькулятор показываем, если есть данные под стратегию.
  const hasCalc =
    !!productPricing &&
    (productPricing.papers.length > 0 ||
      (productPricing.strategy === "multipage" && productPricing.bindings.length > 0) ||
      (productPricing.strategy === "fixed" && productPricing.fixedPrice.length > 0));
  if (hasCalc) pricing = await getPricingData();
  works = await getWorks({ product: slug });
  content = await getServiceContent(slug);
  if (productPricing && pricing) lowPrice = minPrice(productPricing, pricing);
}

// FAQ к выводу: реальный контент из Directus, иначе временная рыба на визитках (см. FISH_FAQ).
const faqItems: ServiceFaq[] =
  content && content.faq.length > 0
    ? content.faq
    : slug === "business-cards"
      ? FISH_FAQ
      : [];

// Интро-текст: Directus, иначе временная рыба на визитках.
const introHtml =
  content?.introText ?? (slug === "business-cards" ? FISH_INTRO : null);

// H1 / мета / JSON-LD страницы.
const h1 = (props.type === "product" && content?.h1) || props.name;
let pageTitle: string;
let pageDescription: string;
const jsonLd: Record<string, unknown>[] = [];
if (props.type === "product") {
  pageTitle =
    content?.metaTitle ??
    `${props.name} в Москве${lowPrice != null ? ` — от ${money(lowPrice)} ₽` : ""} | Printmos`;
  pageDescription =
    content?.metaDescription ??
    `${props.name} на заказ в Москве. Расчёт цены онлайн в конфигураторе, срок от 1 дня. Доставка по Москве и РФ.`;
  jsonLd.push(
    productOffer({ name: props.name, url: pageUrl, lowPrice, description: pageDescription }),
  );
  if (faqItems.length > 0) jsonLd.push(faqPage(faqItems));
} else {
  pageTitle = `${props.name} — Printmos`;
  pageDescription = `${props.name}: услуги печати в Москве.`;
}
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Breadcrumbs items={crumbs} />
  <p class="stub-kicker">
    {props.type === "category" ? "Категория" : "Продукт"}
  </p>
  <h1 class="stub-title">
    {props.icon && <Icon name={props.icon} class="stub-icon" />}
    {h1}
  </h1>

  {
    props.type === "category" && (
      <>
        <p>Страница категории — в разработке. Что входит в категорию:</p>
        <ul class="stub-list">
          {props.items.map((item) => (
            <li>
              <a href={`/${item.slug}`}>
                {item.icon && <Icon name={item.icon} class="menu-icon" />}
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </>
    )
  }

  {
    props.type === "product" && (
      <>
        {/* Первый экран: конфигуратор (мгновенная цена) */}
        {pricing && productPricing ? (
          <ProductConfigurator
            client:load
            product={productPricing}
            pricing={pricing}
            name={props.name}
            slug={slug}
          >
            <Gallery slot="gallery" works={works} />
          </ProductConfigurator>
        ) : (
          <>
            <p>Карточка продукта — калькулятор появится позже.</p>
            <Gallery works={works} />
          </>
        )}

        {/* Плитки видов/опций → кластерные страницы (наполнятся в Фазе 5) */}
        <SegmentTiles items={[]} />

        {/* Интро-текст: вхождения головы + контекстные внутренние ссылки с анкорами
            (05: вхождения хаба). Компактный блок (≤~1000 знаков), не простыня. */}
        {introHtml ? (
          <section class="my-10">
            <h2 class="mb-3 text-xl font-bold">{props.name} в Москве</h2>
            {/* Текст в 2 колонки на всю ширину (как блоки ниже); абзацы не рвём
                между колонками. На мобильных — одна колонка. */}
            <div
              class="text-content gap-8 md:columns-2 [&_p]:break-inside-avoid"
              set:html={introHtml}
            />
          </section>
        ) : (
          <section class="my-10 max-w-prose">
            <h2 class="mb-3 text-xl font-bold">{props.name} в Москве</h2>
            <p class="text-base-content/80">
              {props.name} — печать на заказ в Москве. Расчёт стоимости — мгновенно
              в конфигураторе выше. Срок от 1 рабочего дня. Доставка по Москве и РФ.
            </p>
          </section>
        )}


        {/* Требования к макету + скачиваемый шаблон */}
        {content?.templateUrl && (
          <section class="my-8 max-w-prose">
            <h2 class="mb-3 text-xl font-bold">Требования к макету</h2>
            <p>
              <a class="link" href={content.templateUrl} download>
                Скачать шаблон макета
              </a>{" "}
              · <a class="link link-hover" href="/guides">гайд по подготовке файла</a>
            </p>
          </section>
        )}

        {/* «Материалы и технологии» (слева) + FAQ (справа): рядом на десктопе,
            друг под другом на мобильных. flex-1 + min-w-0 — равные колонки; если
            один блок пуст, второй занимает всю ширину. items-start — колонки не
            тянутся по высоте друг за другом. */}
        <div class="my-10 flex flex-col gap-8 lg:flex-row lg:items-start">
          {/* Авто-блок «Материалы» — из опций продукта (П6, инлайн) */}
          {productPricing && (
            <OptionsInfo
              papers={productPricing.papers}
              finishing={productPricing.finishing}
              foldTypes={productPricing.foldTypes}
              allowContourCut={productPricing.allowContourCut}
              class="lg:min-w-0 lg:flex-1"
            />
          )}

          {/* FAQ (FAQPage JSON-LD уже в <head>) */}
          <Faq items={faqItems} class="lg:min-w-0 lg:flex-1" />
        </div>

        {/* Вверх по иерархии */}
        {props.parentSlug && (
          <p class="my-6 text-base-content/60">
            Категория:{" "}
            <a class="link link-hover" href={`/${props.parentSlug}`}>
              {props.parentName}
            </a>
          </p>
        )}
      </>
    )
  }
</BaseLayout>

<style is:global>
  /* Стили для rich-HTML из Directus (set:html не получает scoped-классы). */
  .text-content a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .text-content a:hover {
    color: var(--color-primary);
  }
  .text-content ul {
    list-style: disc;
    padding-left: 1.25rem;
  }
  .text-content li {
    margin-block: 0.3rem;
  }
  .text-content p + p {
    margin-top: 0.75rem;
  }
</style>
