---
// Общий каталог: все опубликованные продукты, сгруппированные по категориям.
// Плитки и сетка переиспользуют разметку/стили главной (.product-grid /
// .product-tile). Визуал в .product-tile__media — инлайновый SVG сцены продукта,
// отрисованный на сборке (lib/preview/svg/tile.ts, reuse mockups.ts). Multipage
// (книжки, свой stage) пока падают на иконку astro-icon — отдельный заход.
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getCategories } from "../lib/categories";
import { getProducts } from "../lib/products";
import { getPricingData, getProductPricing, minPrice } from "../lib/pricing/data";
import { productTileSvg } from "../lib/preview/svg/tile";
import { coverTileSvg, defaultCoverTileInput } from "../lib/preview/svg/coverTile";

const [categories, products, pricing] = await Promise.all([
  getCategories(),
  getProducts(),
  getPricingData(),
]);

// Один проход по продуктам считает И цену «от», И SVG-плитку сцены: конфиг
// продукта тянется один раз. Цена — честный минимум minPrice(), как на главной
// и в title хабов, чтобы плитка каталога и целевой хаб совпадали.
// Плитка рисуется той же сценой, что и живое превью (reuse mockups.ts), на
// сборке → инлайн-вектор, ноль запросов и JS. Multipage-обложки (свой stage)
// пока падают на иконку — отдельный заход.
const priceBySlug = new Map<string, number | null>();
const tileBySlug = new Map<string, string>();
await Promise.all(
  products.map(async (p) => {
    const cfg = await getProductPricing(p.slug);
    if (!cfg) return;
    priceBySlug.set(p.slug, minPrice(cfg, pricing));
    // Многостраничные рисует свой stage (книжка: корешок, переплёт, кант,
    // кольца, ремешок) из реестра covers.ts; листовые — плоский лист из mockups.
    // Ключ preview_kind общий, просто резолвится в своём реестре.
    if (cfg.strategy === "multipage") {
      tileBySlug.set(p.slug, coverTileSvg(defaultCoverTileInput(cfg)));
    } else if (cfg.previewKind) {
      const size = cfg.sizes[0];
      tileBySlug.set(
        p.slug,
        productTileSvg({
          previewKind: cfg.previewKind,
          mm: size ? { w: size.width, h: size.height } : null,
          sizeLabel: size?.label,
        }),
      );
    }
  }),
);

// Категории в ручном порядке, каждая — со своими опубликованными продуктами.
// Пустые категории (все продукты в черновиках, напр. широкоформат) не выводим.
const groups = categories
  .map((category) => ({
    category,
    items: products.filter((p) => p.category === category.id),
  }))
  .filter((g) => g.items.length > 0);

const totalCount = products.length;

const pageTitle = "Каталог продукции — Printmos";
const pageDescription =
  "Полный каталог цифровой типографии Printmos в Москве: визитки, листовки, буклеты, наклейки, таблички, бланки, конверты и другая печать.";

const lead = "1–3 дня";
const money = (n: number) => n.toLocaleString("ru-RU", { maximumFractionDigits: 0 });
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Breadcrumbs
    items={[
      { name: "Главная", href: "/" },
      { name: "Каталог", href: "/catalog" },
    ]}
  />

  <h1 class="home-title">Каталог продукции</h1>
  <p class="catalog-intro">{totalCount} видов печати — по категориям.</p>

  {
    groups.map((group) => (
      <section class="catalog-section">
        <h2 class="catalog-section__title" id={group.category.slug}>
          {group.category.name}
        </h2>
        <ul class="product-grid">
          {group.items.map((product) => (
            <li>
              <a class="product-tile" href={`/${product.slug}`}>
                <span class="product-tile__media">
                  {tileBySlug.has(product.slug) ? (
                    <Fragment set:html={tileBySlug.get(product.slug)} />
                  ) : (
                    product.icon && (
                      <Icon name={product.icon} class="product-tile__icon" />
                    )
                  )}
                </span>
                <span class="product-tile__body">
                  <span class="product-tile__name">{product.name}</span>
                  <span class="product-tile__price">
                    {priceBySlug.get(product.slug) != null
                      ? `от ${money(priceBySlug.get(product.slug)!)} ₽`
                      : "Рассчитать"}
                  </span>
                  <span class="product-tile__lead">{lead}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</BaseLayout>
