---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactRoute from "../components/ContactRoute.vue";
import RouteClips from "../components/RouteClips.astro";
import ContactForm from "../components/ContactForm.vue";
import { Icon } from "astro-icon/components";
import { getSettings } from "../lib/settings";

// Страница контактов. Композиция:
//  1) Hero в две колонки — слева карта (на всю высоту блока), справа карточка
//     с часами/адресом/людьми. Колонки равной высоты (align: stretch),
//     поэтому под картой нет пустоты.
//  2) Нижний ряд в две колонки: слева целиковый ролик-маршрут от остановки,
//     справа форма-заявка.
// LocalBusiness JSON-LD рендерится глобально в BaseLayout.
const settings = await getSettings();

const officeLat = settings.map_lat ?? 55.751244;
const officeLng = settings.map_lng ?? 37.618423;
const address = settings.address ?? "Москва";
// Контакты-персоны. Телефоны/Telegram — заглушки, заменить на реальные
// (позже можно вынести в Directus как коллекцию team).
const team = [
  {
    role: "Директор",
    phone: settings.phone ?? "+7 495 000-00-00",
    tg: "https://t.me/printmos",
    img: "/team/director.webp",
  },
  {
    role: "Начальник производства",
    phone: "+7 495 000-00-01",
    tg: "https://t.me/printmos_prod",
    img: "/team/production.webp",
  },
];
const telOf = (p: string) => `tel:${p.replace(/[^\d+]/g, "")}`;
// Неразрывные пробелы в номере, чтобы он не переносился по строкам.
const nbsp = (s: string) => s.replace(/ /g, "\u00A0");
// Базовый deep-link до офиса (без точки А — Яндекс спросит сам).
const routeLink = `https://yandex.ru/maps/?mode=routes&rtext=~${officeLat},${officeLng}&rtt=auto`;

// Один целиковый ролик-ориентир: путь от остановки до входа.
const roadClip = [
  {
    label: "Маршрут от остановки «Улица Садовники»",
    mp4: "/route/road.mp4",
    webm: "/route/road.webm",
  },
];

const title = `Контакты — ${settings.company_name ?? "Printmos"}`;
const description =
  "Адрес офиса и самовывоза, телефон, часы работы. Постройте маршрут на машине, транспортом или пешком прямо на карте.";
---

<BaseLayout title={title} description={description}>
  <p class="stub-kicker">Контакты</p>
  <h1 class="stub-title">Как нас найти</h1>
  <p class="contacts-lead">
    Офис и пункт самовывоза в Москве. Постройте маршрут на карте, посмотрите
    путь от остановки или просто напишите нам — ответим в рабочее время.
  </p>

  <!-- 1. Hero: карта + карточка контактов, колонки равной высоты -->
  <div class="contacts-hero">
    <div class="contacts-hero__map">
      <ContactRoute
        client:visible
        apiKey={import.meta.env.PUBLIC_YANDEX_MAPS_KEY}
        officeLat={officeLat}
        officeLng={officeLng}
        address={address}
        companyName={settings.company_name ?? "Printmos"}
        hours={settings.hours}
        phone={settings.phone}
        zoom={settings.map_zoom ?? 16}
      />
    </div>

    <aside class="info-card">
      <section class="info-block">
        <span class="info-block__label">Часы работы</span>
        <div id="open-status" class="os" data-hours={settings.hours ?? ""}>
          <span class="os-dot"></span>
          <span class="os-label">{settings.hours ?? "—"}</span>
        </div>
        {settings.hours && <p class="info-block__muted">{settings.hours}</p>}
      </section>

      <section class="info-block">
        <span class="info-block__label">Адрес</span>
        <p class="info-address">{address}</p>
        <div class="info-actions">
          <button id="copy-address" type="button" class="btn btn-sm" data-address={address}>
            Скопировать
          </button>
          <a
            class="btn btn-sm btn-primary"
            href={routeLink}
            target="_blank"
            rel="noopener"
            aria-label="Построить маршрут в Яндекс.Картах (откроется в новой вкладке)"
          >
            Построить маршрут
          </a>
        </div>
        <span id="copy-status" class="sr-only" role="status" aria-live="polite"></span>
      </section>

      <section class="info-block">
        <span class="info-block__label">Контакты</span>
        <div class="team">
          {team.map((c) => (
            <div class="person">
              <img
                class="person__avatar"
                src={c.img}
                alt={c.role}
                width="112"
                height="112"
                loading="lazy"
              />
              <div class="person__body">
                <span class="person__role">{c.role}</span>
                <a class="person__phone" href={telOf(c.phone)}>{nbsp(c.phone)}</a>
                <a
                  class="person__tg"
                  href={c.tg}
                  target="_blank"
                  rel="noopener"
                  aria-label={`Telegram ${c.role} (откроется в новой вкладке)`}
                >
                  <Icon name="tabler:brand-telegram" />
                  Telegram
                </a>
              </div>
            </div>
          ))}
        </div>
        {settings.email && (
          <a class="info-contact" href={`mailto:${settings.email}`}>
            <Icon name="tabler:mail" />
            {settings.email}
          </a>
        )}
      </section>
    </aside>
  </div>

  <!-- 2. Видео-маршрут + форма-заявка рядом -->
  <section class="contacts-bottom">
    <div class="contacts-bottom__media">
      <h2 class="section-title">Как дойти от остановки</h2>
      <p class="section-sub">
        Остановка «Улица Садовники» — пара минут пешком. Ролик покажет дорогу до входа.
      </p>
      <RouteClips clips={roadClip} />
    </div>

    <div class="contacts-bottom__form">
      <h2 class="section-title">Написать нам</h2>
      <p class="section-sub">Вопрос, заказ или готовый макет — всё одной формой.</p>
      <ContactForm client:visible />
    </div>
  </section>
</BaseLayout>

<style>
  .contacts-lead {
    max-width: 60ch;
    margin: 0 0 2rem;
    font-size: 1.05rem;
    color: color-mix(in oklch, var(--color-base-content) 75%, transparent);
  }

  /* — Общие заголовки секций — */
  .section-title {
    font-size: clamp(1.35rem, 1.1rem + 0.8vw, 1.75rem);
    font-weight: 700;
    line-height: 1.15;
  }
  .section-sub {
    margin: 0.35rem 0 1.25rem;
    color: color-mix(in oklch, var(--color-base-content) 70%, transparent);
  }

  /* — 1. Hero: карта | карточка, равной высоты — */
  .contacts-hero {
    display: grid;
    gap: var(--grid-gap, 1.5rem);
    grid-template-columns: 1.5fr 1fr;
    align-items: stretch;
  }
  /* Карта заполняет всю высоту колонки (= высоте карточки справа) */
  .contacts-hero__map :global(.cr-map) {
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    min-height: 420px;
  }
  @media (max-width: 880px) {
    .contacts-hero {
      grid-template-columns: 1fr;
    }
    /* На мобиле карта снова по соотношению сторон, а не на всю высоту */
    .contacts-hero__map :global(.cr-map) {
      height: auto;
      aspect-ratio: 4 / 3;
    }
  }

  /* Карточка контактов */
  .info-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.4rem 1.5rem;
    border: var(--border, 1px) solid var(--color-base-300);
    border-radius: var(--radius-box, 0.5rem);
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .info-block:not(:last-child) {
    padding-bottom: 1.25rem;
    border-bottom: var(--border, 1px) solid var(--color-base-200);
  }
  .info-block__label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklch, var(--color-base-content) 65%, transparent);
  }
  .info-block__muted {
    font-size: 0.9rem;
    color: color-mix(in oklch, var(--color-base-content) 70%, transparent);
  }

  /* Статус открыто/закрыто */
  .os {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.15rem;
    font-weight: 700;
  }
  .os-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: color-mix(in oklch, var(--color-base-content) 40%, transparent);
    flex: none;
  }
  .os.is-open .os-dot {
    background: #2fb344;
  }

  .info-address {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .info-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .info-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    text-decoration: none;
    color: inherit;
  }
  .info-contact svg {
    width: 1.1rem;
    height: 1.1rem;
    flex: none;
  }
  .info-contact:hover {
    text-decoration: underline;
  }

  /* Контакты-персоны */
  .team {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }
  .person {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .person:not(:last-child) {
    padding-bottom: 1rem;
    border-bottom: var(--border, 1px) solid var(--color-base-200);
  }
  .person__avatar {
    flex: none;
    width: 112px;
    height: 112px;
    border-radius: var(--radius-box, 0.5rem);
    object-fit: cover;
    background: var(--color-base-200);
    border: var(--border, 1px) solid var(--color-base-300);
  }
  .person__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .person__role {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in oklch, var(--color-base-content) 65%, transparent);
  }
  .person__phone {
    font-size: 1.25rem;
    font-weight: 700;
    color: inherit;
    text-decoration: none;
  }
  .person__phone:hover {
    text-decoration: underline;
  }
  .person__tg {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    width: fit-content;
    margin-top: 0.2rem;
    font-size: 0.9rem;
    /* Затемнённый Telegram-голубой: контраст ≥4.5:1 на белом (WCAG AA) */
    color: #1577b0;
    text-decoration: none;
  }
  .person__tg:hover {
    text-decoration: underline;
  }
  .person__tg svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  /* — 2. Видео-маршрут + форма рядом — */
  .contacts-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--grid-gap, 2rem);
    align-items: start;
    margin-top: 3rem;
  }
  @media (max-width: 880px) {
    .contacts-bottom {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { parseHours, openStatus, moscowNow } from "../lib/hours";

  // Живой статус «открыто/закрыто» по московскому времени.
  const el = document.getElementById("open-status");
  const sch = parseHours(el?.dataset.hours);
  if (el && sch) {
    const { day, minutes } = moscowNow();
    const st = openStatus(sch, day, minutes);
    el.classList.toggle("is-open", st.open);
    const label = el.querySelector(".os-label");
    if (label) label.textContent = st.label;
  }

  // Копирование адреса.
  const copyBtn = document.getElementById("copy-address");
  const copyStatus = document.getElementById("copy-status");
  copyBtn?.addEventListener("click", async () => {
    const addr = copyBtn.dataset.address ?? "";
    try {
      await navigator.clipboard.writeText(addr);
      const prev = copyBtn.textContent;
      copyBtn.textContent = "Скопировано";
      if (copyStatus) copyStatus.textContent = "Адрес скопирован";
      setTimeout(() => {
        copyBtn.textContent = prev;
        if (copyStatus) copyStatus.textContent = "";
      }, 1800);
    } catch {
      if (copyStatus) copyStatus.textContent = "Не удалось скопировать адрес";
    }
  });
</script>
