---
import "../assets/app.css";
import { Icon } from "astro-icon/components";
import { Picture } from "astro:assets";
import officeMap from "../assets/office-map.png";
import { getMenu } from "../lib/categories";
import { getSettings } from "../lib/settings";

const menu = await getMenu();
const settings = await getSettings();
const year = new Date().getFullYear();
const { title, description } = Astro.props;

// tel: ссылка из отображаемого телефона (оставляем цифры и +)
const telHref = settings.phone
  ? `tel:${settings.phone.replace(/[^\d+]/g, "")}`
  : null;

// URL виджета Яндекс-карты из координат (для ленивого фасада)
const mapSrc =
  settings.map_lat != null && settings.map_lng != null
    ? `https://yandex.ru/map-widget/v1/?ll=${settings.map_lng}%2C${settings.map_lat}&z=${settings.map_zoom ?? 16}&pt=${settings.map_lng},${settings.map_lat}`
    : null;

---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <header class="site-header page-shell">
      <a class="brand" href="/" aria-label="Printmos">
        <Icon name="logo-pm-mono" class="brand-logo" />
      </a>

      <nav class="site-nav" aria-label="Основная навигация">
        {
          menu.map((category) => (
            <div class="nav-group">
              <a class="nav-group__link" href={`/${category.slug}`}>
                {category.icon && <Icon name={category.icon} class="menu-icon" />}
                {category.name}
              </a>

              {category.products.length > 0 && (
                <div class="nav-group__panel">
                  {category.products.map((product) => (
                    <a href={`/${product.slug}`}>
                      {product.icon && <Icon name={product.icon} class="menu-icon" />}
                      {product.name}
                    </a>
                  ))}
                  <a class="nav-group__all" href={`/${category.slug}`}>
                    Все {category.name} →
                  </a>
                </div>
              )}
            </div>
          ))
        }
      </nav>

      <div class="site-contact">
        {telHref && <a class="site-phone" href={telHref}>{settings.phone}</a>}
        {settings.hours && <span class="site-hours">{settings.hours}</span>}
      </div>

      <div class="dropdown dropdown-end nav-hamburger">
        <div tabindex="0" role="button" class="btn btn-ghost" aria-label="Меню">
          <span class="ham-icon">
            <svg
              class="ham-open"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
            <svg
              class="ham-close"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="5" y1="5" x2="19" y2="19" />
              <line x1="19" y1="5" x2="5" y2="19" />
            </svg>
          </span>
        </div>

        <ul
          tabindex="0"
          class="menu dropdown-content z-30 mt-3 w-72 bg-base-100 border border-base-content"
        >
          {
            menu.map((category) => (
              <li>
                <details>
                  <summary>
                    {category.icon && <Icon name={category.icon} class="menu-icon" />}
                    {category.name}
                  </summary>
                  <ul>
                    {category.products.map((product) => (
                      <li>
                        <a href={`/${product.slug}`}>
                          {product.icon && <Icon name={product.icon} class="menu-icon" />}
                          {product.name}
                        </a>
                      </li>
                    ))}
                    <li>
                      <a href={`/${category.slug}`}>Все {category.name} →</a>
                    </li>
                  </ul>
                </details>
              </li>
            ))
          }
          {telHref && (
            <li>
              <a href={telHref}>{settings.phone}</a>
            </li>
          )}
        </ul>
      </div>
    </header>

    <main class="page-shell">
      <slot />
    </main>

    <footer class="site-footer page-shell">
      <!-- 1. Карта: ленивый фасад → клик подгружает ч/б интерактив Яндекса -->
      <div
        class="footer-block map-block"
        data-map-src={mapSrc}
        role="button"
        tabindex="0"
        aria-label="Открыть интерактивную карту проезда"
      >
        <Picture
          class="map-img"
          src={officeMap}
          formats={["avif", "webp"]}
          quality={25}
          alt="Карта проезда к офису Printmos"
          width={450}
          height={450}
          loading="lazy"
        />
        <Icon name="tabler:map-pin-filled" class="map-marker" />
        <span class="map-bubble">{settings.address ?? "Москва"}</span>
      </div>

      <!-- 2. Компания -->
      <nav class="footer-block footer-company">
        <h6 class="footer-title">Компания</h6>
        <a href="/o-nas">О нас</a>
        <a href="/portfolio">Портфолио</a>
        <a href="/guides">Гайды по макетам</a>
        <a href="/garantii">Гарантии и отзывы</a>
        <a href="/kak-zakazat">Как заказать</a>
      </nav>

      <!-- 3. Оплата и доставка -->
      <div class="footer-block footer-pay">
        <h6 class="footer-title">Оплата и доставка</h6>
        <ul class="pay-list">
          <li><Icon name="tabler:credit-card" />Карты Visa / MIR</li>
          <li><Icon name="tabler:qrcode" />СБП по QR-коду</li>
          <li><Icon name="tabler:cash" />Наличные</li>
          <li><Icon name="tabler:file-invoice" />Счёт для юрлиц</li>
          <li><Icon name="tabler:building-store" />Самовывоз</li>
          <li><Icon name="tabler:truck-delivery" />Доставка по Москве и РФ</li>
        </ul>
      </div>

      <!-- 4. Контакты -->
      <div class="footer-block contact-card">
        <span class="contact-card__label">Контакты</span>
        {telHref && <a class="contact-card__phone" href={telHref}>{settings.phone}</a>}
        {
          settings.email && (
            <a class="contact-card__line" href={`mailto:${settings.email}`}>
              {settings.email}
            </a>
          )
        }
        {settings.address && <p class="contact-card__line">{settings.address}</p>}
        {
          settings.hours && (
            <p class="contact-card__line contact-card__muted">{settings.hours}</p>
          )
        }
        <div class="messengers">
          {
            settings.telegram_url && (
              <a class="messenger" href={settings.telegram_url} target="_blank" rel="noopener" aria-label="Telegram">
                <Icon name="tabler:brand-telegram" />
              </a>
            )
          }
          {
            settings.whatsapp_url && (
              <a class="messenger" href={settings.whatsapp_url} target="_blank" rel="noopener" aria-label="WhatsApp">
                <Icon name="tabler:brand-whatsapp" />
              </a>
            )
          }
        </div>
      </div>
    </footer>

    <div class="footer-bottom page-shell">
      <span>© {year} Printmos — цифровая типография в Москве</span>
    </div>

    <!-- Мобильная липкая панель действий (только на узких экранах) -->
    <div class="mobile-bar">
      <div class="mobile-bar__row">
        {
          telHref && (
            <a class="mobile-bar__btn" href={telHref}>
              <Icon name="tabler:phone" />
              Позвонить
            </a>
          )
        }
        <a class="mobile-bar__btn" href="/">
          <Icon name="tabler:calculator" />
          Расчет
        </a>
        <button type="button" class="mobile-bar__btn" data-sheet-open>
          <Icon name="tabler:message" />
          Чат
        </button>
      </div>
    </div>

    <!-- Шторка выбора канала связи -->
    <dialog class="channel-sheet" id="channelSheet">
      <form method="dialog" class="channel-sheet__inner">
        <p class="channel-sheet__title">Связаться</p>
        {
          settings.whatsapp_url && (
            <a
              class="channel-sheet__link"
              id="chWhatsapp"
              data-base={settings.whatsapp_url}
              href={settings.whatsapp_url}
              target="_blank"
              rel="noopener"
            >
              <Icon name="tabler:brand-whatsapp" />
              WhatsApp
            </a>
          )
        }
        {
          settings.telegram_url && (
            <a class="channel-sheet__link" href={settings.telegram_url} target="_blank" rel="noopener">
              <Icon name="tabler:brand-telegram" />
              Telegram
            </a>
          )
        }
        {
          telHref && (
            <a class="channel-sheet__link" href={telHref}>
              <Icon name="tabler:phone" />
              Позвонить
            </a>
          )
        }
        <p class="channel-sheet__note">Обычно отвечаем за 10–15 минут в рабочее время.</p>
        <button class="channel-sheet__close" value="cancel">Закрыть</button>
      </form>
    </dialog>

    <script>
      // Ленивый фасад карты. Грузим iframe ДО нажатия — по наведению (hover),
      // чтобы перетаскивание сразу шло по живой карте, а не по статичной картинке.
      document.querySelectorAll<HTMLElement>(".map-block").forEach((el) => {
        const src = el.dataset.mapSrc;
        if (!src) return;
        let loaded = false;
        const open = () => {
          if (loaded) return;
          loaded = true;
          const iframe = document.createElement("iframe");
          iframe.src = src;
          iframe.title = "Карта проезда";
          iframe.allowFullscreen = true;
          el.classList.add("map-block--active");
          el.removeAttribute("role");
          el.removeAttribute("tabindex");
          el.replaceChildren(iframe);
        };
        el.addEventListener("pointerenter", open); // десктоп: hover до клика
        el.addEventListener("pointerdown", open); // тач: первое касание
        el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            open();
          }
        });
      });

      // Шторка каналов: одна заготовка сообщения для WhatsApp.
      const sheet = document.getElementById("channelSheet") as HTMLDialogElement | null;
      const wa = document.getElementById("chWhatsapp") as HTMLAnchorElement | null;
      const chatMessage = "Здравствуйте! Хочу задать вопрос по печати.";
      if (wa?.dataset.base) {
        wa.href = `${wa.dataset.base}?text=${encodeURIComponent(chatMessage)}`;
      }
      document.querySelectorAll<HTMLElement>("[data-sheet-open]").forEach((btn) => {
        btn.addEventListener("click", () => sheet?.showModal());
      });
    </script>
  </body>
</html>