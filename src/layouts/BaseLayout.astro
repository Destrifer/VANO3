---
import "../assets/app.css";
import { Icon } from "astro-icon/components";
import { Picture } from "astro:assets";
import officeMap from "../assets/office-map.png";
import { getMenu } from "../lib/categories";
import { getSettings } from "../lib/settings";
import { getDeliveryMethods } from "../lib/delivery";
import CartButton from "../components/CartButton.vue";
import JsonLd from "../components/seo/JsonLd.astro";
import YandexMetrika from "../components/seo/YandexMetrika.astro";
import { localBusiness } from "../lib/seo/jsonld";

const menu = await getMenu();
const settings = await getSettings();
// Способы доставки — глобально, для островов (плашка товара + корзина) читают JSON
// из #delivery-methods на маунте (как мета lead-cutoff), без prop-drilling.
const deliveryMethods = await getDeliveryMethods();
const year = new Date().getFullYear();
// jsonLd: массив объектов Schema.org для конкретной страницы (Product/Breadcrumb/FAQ).
const {
  title,
  description,
  canonical: canonicalProp,
  ogImage,
  noindex = false,
  jsonLd = [],
} = Astro.props as {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
};

// tel: ссылка из отображаемого телефона (оставляем цифры и +)
const telHref = settings.phone
  ? `tel:${settings.phone.replace(/[^\d+]/g, "")}`
  : null;

// URL виджета Яндекс-карты из координат (для ленивого фасада)
const mapSrc =
  settings.map_lat != null && settings.map_lng != null
    ? `https://yandex.ru/map-widget/v1/?ll=${settings.map_lng}%2C${settings.map_lat}&z=${settings.map_zoom ?? 16}&pt=${settings.map_lng},${settings.map_lat}`
    : null;

// — SEO-обвязка <head> —
const siteUrl = Astro.site?.toString() ?? "https://printmos.ru";
// Канонический URL: по умолчанию текущий путь на каноническом домене;
// pSEO-страница может передать свой через проп (док 05 §60).
const canonical =
  canonicalProp ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : null;
// Глобальная разметка бизнеса — на всех страницах (брендовый + локальный).
const businessLd = localBusiness(settings, siteUrl);
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="lead-cutoff" content={String(settings.cutoff_hour ?? 14)} />
    <meta name="free-delivery-threshold" content={String(settings.free_delivery_threshold ?? 20000)} />
    <script type="application/json" id="delivery-methods" is:inline set:html={JSON.stringify(deliveryMethods)}></script>
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph + Twitter — превью при расшаривании */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={settings.company_name ?? "Printmos"} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    {/* Глобальная разметка бизнеса (LocalBusiness/Organization) на всех страницах */}
    <JsonLd data={businessLd} />
    {jsonLd.map((block) => <JsonLd data={block} />)}

    {/* Speculation Rules: префетч вероятного следующего перехода (док 02 §18) */}
    <script
      type="speculationrules"
      is:inline
      set:html={JSON.stringify({
        prefetch: [
          { source: "document", where: { href_matches: "/*" }, eagerness: "moderate" },
        ],
      })}
    />

    <script is:inline>
      // Ранний гейт лайтбокса: инлайн в <head>, активен ДО загрузки бандлов —
      // закрывает окно «превью уже кликабельно, а JS ещё не исполнился».
      // Клик по галерее до готовности PhotoSwipe не пускаем по ссылке (иначе
      // откроется оригинал фото), запоминаем в __pmLbPending и будим загрузчик
      // из BaseLayout-скрипта (__pmLbEnsure). Если бандл так и не исполнился —
      // через 2.5 с отпускаем клик в нативную ссылку (деградация как без JS).
      (function () {
        window.addEventListener("pageshow", function (e) {
          if (e.persisted) window.__pmLbPending = null; // bfcache: забыть старый клик
        });
        document.addEventListener(
          "click",
          function (e) {
            if (window.__pmLbReady) return; // PhotoSwipe готов — перехватит сам
            // модификаторы/средняя кнопка — нативное «открыть в новой вкладке»
            if (e.ctrlKey || e.metaKey || e.shiftKey || e.altKey || e.button > 0) return;
            var t = e.target && e.target.closest && e.target.closest(".gallery a.gallery__link");
            if (!t) return;
            e.preventDefault();
            window.__pmLbPending = t;
            if (window.__pmLbEnsure) {
              window.__pmLbEnsure();
            } else {
              setTimeout(function () {
                if (window.__pmLbEnsure) window.__pmLbEnsure();
                else if (!window.__pmLbReady && window.__pmLbPending) {
                  window.__pmLbReady = true;
                  var l = window.__pmLbPending;
                  window.__pmLbPending = null;
                  l.click();
                }
              }, 2500);
            }
          },
          true,
        );
      })();
    </script>

    <slot name="head" />
  </head>

  <body>
    <header class="site-header page-shell">
      <a class="brand" href="/" aria-label="Printmos">
        <Icon name="logo-pm-mono" class="brand-logo" />
      </a>

      <nav class="site-nav" aria-label="Основная навигация">
        {
          menu.map((category) => (
            <div class="nav-group">
              <a class="nav-group__link" href={`/${category.slug}`}>
                {category.icon && <Icon name={category.icon} class="menu-icon" />}
                {category.name}
              </a>

              {category.products.length > 0 && (
                <div class="nav-group__panel">
                  {category.products.map((product) => (
                    <a href={`/${product.slug}`}>
                      {product.icon && <Icon name={product.icon} class="menu-icon" />}
                      {product.name}
                    </a>
                  ))}
                  <a class="nav-group__all" href={`/${category.slug}`}>
                    Все {category.name} →
                  </a>
                </div>
              )}
            </div>
          ))
        }
      </nav>

      <div class="site-contact">
        {telHref && <a class="site-phone" href={telHref}>{settings.phone}</a>}
        {settings.hours && <span class="site-hours">{settings.hours}</span>}
      </div>

      <CartButton client:only="vue" />

      <div class="dropdown dropdown-end nav-hamburger">
        <div tabindex="0" role="button" class="btn btn-ghost" aria-label="Меню">
          <span class="ham-icon">
            <svg
              class="ham-open"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
            <svg
              class="ham-close"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <line x1="5" y1="5" x2="19" y2="19" />
              <line x1="19" y1="5" x2="5" y2="19" />
            </svg>
          </span>
        </div>

        <ul
          tabindex="0"
          class="menu dropdown-content z-30 mt-3 w-72 bg-base-100 border border-base-content"
        >
          {
            menu.map((category) => (
              <li>
                <details>
                  <summary>
                    {category.icon && <Icon name={category.icon} class="menu-icon" />}
                    {category.name}
                  </summary>
                  <ul>
                    {category.products.map((product) => (
                      <li>
                        <a href={`/${product.slug}`}>
                          {product.icon && <Icon name={product.icon} class="menu-icon" />}
                          {product.name}
                        </a>
                      </li>
                    ))}
                    <li>
                      <a href={`/${category.slug}`}>Все {category.name} →</a>
                    </li>
                  </ul>
                </details>
              </li>
            ))
          }
          {telHref && (
            <li>
              <a href={telHref}>{settings.phone}</a>
            </li>
          )}
        </ul>
      </div>
    </header>

    <main class="page-shell">
      <slot />
    </main>

    <footer class="site-footer page-shell">
      <!-- 1. Карта: ленивый фасад → клик подгружает ч/б интерактив Яндекса -->
      <div
        class="footer-block map-block"
        data-map-src={mapSrc}
        role="button"
        tabindex="0"
        aria-label="Открыть интерактивную карту проезда"
      >
        <Picture
          class="map-img"
          src={officeMap}
          formats={["avif", "webp"]}
          quality={25}
          alt="Карта проезда к офису Printmos"
          width={450}
          height={450}
          loading="lazy"
        />
        <Icon name="tabler:map-pin-filled" class="map-marker" aria-hidden="true" />
        <span class="map-bubble">{settings.address ?? "Москва"}</span>
      </div>

      <!-- 2. Компания -->
      <nav class="footer-block footer-company">
        <h6 class="footer-title">Компания</h6>
        <a href="/o-nas">О нас</a>
        <a href="/works">Портфолио</a>
        <a href="/dostavka-oplata">Доставка и оплата</a>
        <a href="/contacts">Контакты</a>
      </nav>

      <!-- 3. Оплата и доставка -->
      <div class="footer-block footer-pay">
        <h6 class="footer-title">Оплата и доставка</h6>
        <ul class="pay-list">
          <li><Icon name="tabler:credit-card" />Карты Visa / MIR</li>
          <li><Icon name="tabler:qrcode" />СБП по QR-коду</li>
          <li><Icon name="tabler:cash" />Наличные</li>
          <li><Icon name="tabler:file-invoice" />Счёт для юрлиц</li>
          <li><Icon name="tabler:building-store" />Самовывоз</li>
          <li><Icon name="tabler:truck-delivery" />Доставка по Москве и РФ</li>
        </ul>
        <a class="footer-pay__more" href="/dostavka-oplata">Подробнее об оплате и доставке</a>
      </div>

      <!-- 4. Контакты -->
      <div class="footer-block contact-card">
        <span class="contact-card__label">Контакты</span>
        {telHref && <a class="contact-card__phone" href={telHref}>{settings.phone}</a>}
        {
          settings.email && (
            <a class="contact-card__line" href={`mailto:${settings.email}`}>
              {settings.email}
            </a>
          )
        }
        {settings.address && <p class="contact-card__line">{settings.address}</p>}
        {
          settings.hours && (
            <p class="contact-card__line contact-card__muted">{settings.hours}</p>
          )
        }
        <div class="messengers">
          {
            settings.telegram_url && (
              <a class="messenger" href={settings.telegram_url} target="_blank" rel="noopener" aria-label="Telegram">
                <Icon name="tabler:brand-telegram" />
              </a>
            )
          }
          {
            settings.whatsapp_url && (
              <a class="messenger" href={settings.whatsapp_url} target="_blank" rel="noopener" aria-label="WhatsApp">
                <Icon name="tabler:brand-whatsapp" />
              </a>
            )
          }
        </div>
      </div>
    </footer>

    <div class="footer-bottom page-shell">
      <span>© {year} Printmos — цифровая типография в Москве</span>
    </div>

    <!-- Мобильная липкая панель действий (только на узких экранах) -->
    <div class="mobile-bar">
      <div class="mobile-bar__row">
        {
          telHref && (
            <a class="btn btn-ghost flex-1 flex-col gap-1 h-auto py-2 text-xs font-normal [&_svg]:size-6" href={telHref}>
              <Icon name="tabler:phone" />
              Позвонить
            </a>
          )
        }
        <a class="btn btn-ghost flex-1 flex-col gap-1 h-auto py-2 text-xs font-normal [&_svg]:size-6" href="/">
          <Icon name="tabler:calculator" />
          Расчет
        </a>
        <button type="button" class="btn btn-ghost flex-1 flex-col gap-1 h-auto py-2 text-xs font-normal [&_svg]:size-6" data-sheet-open>
          <Icon name="tabler:message" />
          Чат
        </button>
      </div>
    </div>

    <!-- Шторка выбора канала связи (daisyUI modal, снизу на мобиле, по центру на десктопе) -->
    <dialog class="modal modal-bottom sm:modal-middle" id="channelSheet">
      <div class="modal-box flex flex-col gap-3 max-w-md [&_svg]:size-5">
        <h3 class="font-bold text-lg">Связаться</h3>
        {
          settings.whatsapp_url && (
            <a
              class="btn btn-outline justify-start gap-2"
              id="chWhatsapp"
              data-base={settings.whatsapp_url}
              href={settings.whatsapp_url}
              target="_blank"
              rel="noopener"
            >
              <Icon name="tabler:brand-whatsapp" />
              WhatsApp
            </a>
          )
        }
        {
          settings.telegram_url && (
            <a class="btn btn-outline justify-start gap-2" href={settings.telegram_url} target="_blank" rel="noopener">
              <Icon name="tabler:brand-telegram" />
              Telegram
            </a>
          )
        }
        {
          telHref && (
            <a class="btn btn-outline justify-start gap-2" href={telHref}>
              <Icon name="tabler:phone" />
              Позвонить
            </a>
          )
        }
        <p class="text-sm opacity-60">Обычно отвечаем за 10–15 минут в рабочее время.</p>
        <form method="dialog">
          <button class="btn btn-ghost btn-block" value="cancel">Закрыть</button>
        </form>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>закрыть</button>
      </form>
    </dialog>

    <script>
      // Срок готовности: заполняем все .ready-badge живой фразой и обновляем в
      // реальном времени (в отсечку/полночь фраза сама перещёлкивается).
      import { formatLead, msToNextLeadBoundary } from "../lib/leadtime";
      const cutoff =
        Number(document.querySelector('meta[name="lead-cutoff"]')?.getAttribute("content")) || 14;
      const renderBadges = () => {
        const now = new Date();
        document.querySelectorAll<HTMLElement>(".ready-badge[data-ready-lead]").forEach((el) => {
          const lead = Number(el.dataset.readyLead) || 1;
          const { text, title } = formatLead(now, lead, cutoff);
          const t = el.querySelector<HTMLElement>(".ready-badge__text");
          if (t) t.textContent = text;
          el.title = title;
        });
      };
      const scheduleBadges = () => {
        setTimeout(() => {
          renderBadges();
          scheduleBadges();
        }, msToNextLeadBoundary(new Date(), cutoff));
      };
      renderBadges();
      scheduleBadges();
    </script>

    <script>
      // Ленивый фасад карты. Грузим iframe ДО нажатия — по наведению (hover),
      // чтобы перетаскивание сразу шло по живой карте, а не по статичной картинке.
      document.querySelectorAll<HTMLElement>(".map-block").forEach((el) => {
        const src = el.dataset.mapSrc;
        if (!src) return;
        let loaded = false;
        const open = () => {
          if (loaded) return;
          loaded = true;
          const iframe = document.createElement("iframe");
          iframe.src = src;
          iframe.title = "Карта проезда";
          iframe.allowFullscreen = true;
          el.classList.add("map-block--active");
          el.removeAttribute("role");
          el.removeAttribute("tabindex");
          el.replaceChildren(iframe);
        };
        el.addEventListener("pointerenter", open); // десктоп: hover до клика
        el.addEventListener("pointerdown", open); // тач: первое касание
        el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            open();
          }
        });
      });

      // Шторка каналов: одна заготовка сообщения для WhatsApp.
      const sheet = document.getElementById("channelSheet") as HTMLDialogElement | null;
      const wa = document.getElementById("chWhatsapp") as HTMLAnchorElement | null;
      const chatMessage = "Здравствуйте! Хочу задать вопрос по печати.";
      if (wa?.dataset.base) {
        wa.href = `${wa.dataset.base}?text=${encodeURIComponent(chatMessage)}`;
      }
      document.querySelectorAll<HTMLElement>("[data-sheet-open]").forEach((btn) => {
        btn.addEventListener("click", () => sheet?.showModal());
      });

      // Лайтбокс галереи (PhotoSwipe). Клики до готовности перехватывает ранний
      // инлайн-гейт в <head> (__pmLbPending/__pmLbReady) — он закрывает гонку
      // «кликнул раньше, чем исполнился этот бандл». Здесь — загрузчик: модуль
      // подключаем ТОЛЬКО если на странице есть галерея, и ТОЛЬКО в простое —
      // на начальную загрузку 0 КБ, CWV не страдают. Тяжёлое ядро photoswipe
      // грузится уже внутри, при открытии.
      const w = window as unknown as {
        __pmLbReady?: boolean;
        __pmLbPending?: HTMLAnchorElement | null;
        __pmLbEnsure?: () => void;
      };
      if (document.querySelector(".gallery a.gallery__link")) {
        let loading: Promise<unknown> | null = null;
        // Снимаем гейт и доигрываем отложенный клик. При успехе его перехватит
        // PhotoSwipe; при ошибке загрузки (сеть) сработает нативная ссылка —
        // откроется фото, как без JS. Идемпотентно: pending обнуляется.
        const release = () => {
          w.__pmLbReady = true;
          const l = w.__pmLbPending;
          w.__pmLbPending = null;
          l?.click();
        };
        const ensure = () => {
          if (!loading) loading = import("../scripts/gallery-lightbox").catch(() => {});
          loading.then(release);
        };
        w.__pmLbEnsure = ensure;
        if (w.__pmLbPending) ensure(); // кликнули раньше, чем исполнился бандл

        // Прелоад в простое, чтобы к первому клику обычно уже было готово.
        if ("requestIdleCallback" in window) requestIdleCallback(() => ensure());
        else setTimeout(ensure, 1200);
      }
    </script>

    <YandexMetrika />
  </body>
</html>