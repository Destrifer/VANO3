# Прод-переменные для docker-compose.prod.yml. Скопировать в .env.production на сервере
# и заполнить РЕАЛЬНЫМИ секретами (НЕ локальные значения). .env.production в гите игнорится.
# Запуск: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- образ Directus ---
DIRECTUS_IMAGE=directus/directus:11.5.1

# --- публичные URL/домены ---
# Публичный URL Directus (поддомен админки). Используется и сайтом для ассет-ссылок картинок.
DIRECTUS_PUBLIC_URL=https://admin.printmos.ru
# Origin основного сайта (для CORS Directus).
SITE_ORIGIN=https://printmos.ru

# --- Directus core (СГЕНЕРИРОВАТЬ новые, напр. `openssl rand -hex 32`) ---
DIRECTUS_KEY=replace-with-secure-random-key
DIRECTUS_SECRET=replace-with-secure-random-secret
DIRECTUS_ADMIN_EMAIL=admin@printmos.ru
DIRECTUS_ADMIN_PASSWORD=replace-with-strong-admin-password

# --- PostgreSQL ---
POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=replace-with-strong-db-password

# --- сервис-токен Astro /api (роль «Order Service»: create на orders/order_items/directus_files) ---
DIRECTUS_TOKEN=replace-with-prod-order-service-static-token

# --- DaData (подсказки адресов) ---
DADATA_TOKEN=replace-with-dadata-token
DADATA_SECRET=replace-with-dadata-secret

# --- Яндекс.Карты JS API (защищается доменом в кабинете) ---
PUBLIC_YANDEX_MAPS_KEY=replace-with-yandex-maps-js-api-key

# --- Уведомления о заявках (опционально; пустой канал пропускается) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REQUEST_NOTIFY_EMAIL=

# --- Подпись токена формы (антиспам) ---
FORM_SIGNING_SECRET=replace-with-random-secret
