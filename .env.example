DIRECTUS_IMAGE=directus/directus:11.5.1
DIRECTUS_PORT=8055
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_CORS_ORIGIN=http://localhost:4321

DIRECTUS_KEY=replace-with-secure-random-key
DIRECTUS_SECRET=replace-with-secure-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=replace-with-secure-admin-password

POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=replace-with-secure-database-password

# Серверные эндпоинты Astro (/api/*) — токен сервисной роли «Order Service»
# (права: create на orders/order_items/directus_files). Только сервер.
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=replace-with-order-service-static-token

# DaData (подсказки адресов) — токен для подсказок, секрет для стандартизации
DADATA_TOKEN=replace-with-dadata-api-token
DADATA_SECRET=replace-with-dadata-secret
